APP_NAME="Goriya Backend Laravel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=goriya_laravel
DB_USERNAME=postgres
DB_PASSWORD=

# Requis pour l'auth JWT (voir config/jwt.php), pas de repli en dur toléré
JWT_SECRET=

# Optionnel : clé Anthropic pour l'analyse CV/scoring/matching (fallback statique sinon)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Requis pour les paiements Kkiapay (voir config/services.php) — clés du
# dashboard Kkiapay (sandbox ou production selon KKIAPAY_SANDBOX)
KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET=
KKIAPAY_SANDBOX=true

# Gateways de paiement actifs, résolus par PaymentGatewayManager. Wave et
# Stripe sont implémentés mais désactivés par défaut — n'ajouter que si le
# besoin business est confirmé (voir plan V1 paiements).
PAYMENT_ENABLED_GATEWAYS=kkiapay
PAYMENT_DEFAULT_GATEWAY=kkiapay

# Requis uniquement si "wave" est ajouté à PAYMENT_ENABLED_GATEWAYS
WAVE_API_KEY=

# Requis uniquement si "stripe" est ajouté à PAYMENT_ENABLED_GATEWAYS
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
